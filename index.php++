<script>
document.addEventListener("DOMContentLoaded", function () {
  const btn = document.getElementById("curriculumLoadMore");
  const more = document.getElementById("curriculumMore");

  if (!btn || !more) return;

  btn.addEventListener("click", function () {
    const expanded = btn.getAttribute("aria-expanded") === "true";

    if (!expanded) {
      more.classList.remove("hidden");
      btn.setAttribute("aria-expanded", "true");
      btn.querySelector("span")?.remove();
      btn.innerHTML = `
        Show Less
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 rotate-180 transition-transform" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"></path>
        </svg>
      `;
    } else {
      more.classList.add("hidden");
      btn.setAttribute("aria-expanded", "false");
      btn.innerHTML = `
        Read More
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"></path>
        </svg>
      `;
    }
  });
});
</script>

