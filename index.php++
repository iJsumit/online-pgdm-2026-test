<script>
(function () {
  function initRecruitersAutoScroll() {
    const tracks = document.querySelectorAll(".recruitersTrack");
    const nextBtn = document.getElementById("recruitersNext");
    const prevBtn = document.getElementById("recruitersPrev");

    if (!tracks.length) return;

    // Find the shared viewport (your overflow-hidden wrapper)
    const viewport = tracks[0].closest(".overflow-hidden");
    if (!viewport) return;

    let x = 0;
    let timer = null;
    const DELAY = 2500; // autoplay speed (ms)
    const DURATION = 600; // slide animation (ms)

    // Ensure smooth transition (even if tailwind class fails)
    tracks.forEach(t => {
      t.style.transition = `transform ${DURATION}ms ease`;
      t.style.willChange = "transform";
    });

    function metrics() {
      const step = viewport.clientWidth; // move by viewport width (page-wise)
      const maxTranslate = Math.max(0, tracks[0].scrollWidth - viewport.clientWidth);
      return { step, maxTranslate };
    }

    function applyTransform() {
      tracks.forEach(t => {
        t.style.transform = `translate3d(${-x}px, 0, 0)`;
      });
    }

    function next() {
      const { step, maxTranslate } = metrics();

      // If widths not ready yet, skip this tick
      if (!step) return;

      x += step;

      // loop back
      if (x > maxTranslate + 2) x = 0;

      applyTransform();
    }

    function prev() {
      const { step } = metrics();
      if (!step) return;

      x = Math.max(0, x - step);
      applyTransform();
    }

    function start() {
      stop();
      timer = setInterval(next, DELAY);
    }

    function stop() {
      if (timer) clearInterval(timer);
      timer = null;
    }

    // Buttons
    if (nextBtn) {
      nextBtn.addEventListener("click", () => {
        next();
        start();
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener("click", () => {
        prev();
        start();
      });
    }

    // Pause on hover
    viewport.addEventListener("mouseenter", stop);
    viewport.addEventListener("mouseleave", start);

    // Pause when tab hidden
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });

    // Reset on resize
    window.addEventListener("resize", () => {
      x = 0;
      applyTransform();
      start();
    });

    // Start autoplay
    start();
  }

  // IMPORTANT: wait for full load so widths are correct
  window.addEventListener("load", initRecruitersAutoScroll);
})();
</script>


