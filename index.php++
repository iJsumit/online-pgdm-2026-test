        <section id="curriculum" class="py-12 md:py-10 bg-gray-50 scroll-mt-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 md:mb-8">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-[#573865] mb-3">
        Curriculum Designed for Real Results
      </h2>
    </div>

    <div class="space-y-3" data-accordion="curriculum">
      <!-- Item 1 (VISIBLE by default) -->
      <div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
        <button
          type="button"
          class="w-full flex items-center justify-between p-4 md:p-5 hover:bg-gray-50 transition-colors text-left"
          data-acc-trigger
          aria-expanded="false"
          aria-controls="sem1"
        >
          <span class="font-semibold text-[#573865]">Semester 1: Foundation</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="acc-icon lucide lucide-chevron-down w-5 h-5 text-gray-400 transition-transform">
            <path d="m6 9 6 6 6-6"></path>
          </svg>
        </button>

        <div id="sem1" class="acc-panel px-4 md:px-5 pb-4 md:pb-5" hidden>
          <ul class="grid md:grid-cols-2 gap-2 text-sm text-gray-600">
            <li>• Managerial Economics</li>
            <li>• Accounting for Managers</li>
            <li>• Organizational Behaviour</li>
            <li>• Business Communication</li>
            <li>• Quantitative Techniques</li>
            <li>• Business Environment</li>
          </ul>
        </div>
      </div>

      <!-- HIDDEN ITEMS WRAP -->
      <div id="curriculumMore" class="space-y-3 hidden">
        <!-- Item 2 -->
        <div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
          <button
            type="button"
            class="w-full flex items-center justify-between p-4 md:p-5 hover:bg-gray-50 transition-colors text-left"
            data-acc-trigger
            aria-expanded="false"
            aria-controls="sem2"
          >
            <span class="font-semibold text-[#573865]">Semester 2: Core Business</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="acc-icon lucide lucide-chevron-down w-5 h-5 text-gray-400 transition-transform">
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </button>

          <div id="sem2" class="acc-panel px-4 md:px-5 pb-4 md:pb-5" hidden>
            <ul class="grid md:grid-cols-2 gap-2 text-sm text-gray-600">
              <li>• Marketing Management</li>
              <li>• Financial Management</li>
              <li>• Human Resource Management</li>
              <li>• Operations Management</li>
              <li>• Business Research Methods</li>
              <li>• Legal Aspects of Business</li>
            </ul>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
          <button
            type="button"
            class="w-full flex items-center justify-between p-4 md:p-5 hover:bg-gray-50 transition-colors text-left"
            data-acc-trigger
            aria-expanded="false"
            aria-controls="sem3"
          >
            <span class="font-semibold text-[#573865]">Semester 3: Specialization</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="acc-icon lucide lucide-chevron-down w-5 h-5 text-gray-400 transition-transform">
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </button>

          <div id="sem3" class="acc-panel px-4 md:px-5 pb-4 md:pb-5" hidden>
            <div class="text-sm text-gray-600 mb-3">
              Choose electives aligned to your specialization.
            </div>
            <ul class="grid md:grid-cols-2 gap-2 text-sm text-gray-600">
              <li>• Advanced Marketing / Digital</li>
              <li>• Corporate Finance / Investments</li>
              <li>• People Analytics / Talent</li>
              <li>• Supply Chain / Ops Analytics</li>
              <li>• Business Analytics Foundations</li>
              <li>• Industry Project 1</li>
            </ul>
          </div>
        </div>

        <!-- Item 4 -->
        <div class="border border-gray-200 rounded-xl overflow-hidden bg-white">
          <button
            type="button"
            class="w-full flex items-center justify-between p-4 md:p-5 hover:bg-gray-50 transition-colors text-left"
            data-acc-trigger
            aria-expanded="false"
            aria-controls="sem4"
          >
            <span class="font-semibold text-[#573865]">Semester 4: Capstone</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="acc-icon lucide lucide-chevron-down w-5 h-5 text-gray-400 transition-transform">
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </button>

          <div id="sem4" class="acc-panel px-4 md:px-5 pb-4 md:pb-5" hidden>
            <ul class="grid md:grid-cols-2 gap-2 text-sm text-gray-600">
              <li>• Strategy & Leadership</li>
              <li>• Business Ethics & Governance</li>
              <li>• Industry Project 2</li>
              <li>• Capstone Project</li>
              <li>• Career Readiness</li>
              <li>• Viva / Final Evaluation</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- LOAD MORE BUTTON -->
      <div class="pt-2">
  <button
  id="curriculumLoadMore"
  type="button"
  class="mx-auto flex items-center gap-2 px-4 py-2 text-sm rounded-lg bg-[#573865] text-white font-medium hover:bg-[#4b2f57] transition-colors"
  aria-expanded="false"
  aria-controls="curriculumMore"
>
  Read More
  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform" viewBox="0 0 24 24" fill="none"
    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="m6 9 6 6 6-6"></path>
  </svg>
</button>
      </div>

    </div>
  </div>
</section>

