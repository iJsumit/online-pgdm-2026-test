         <section id="Eligibility" class="py-12 md:py-10 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-[#573865]">
        Eligibility
      </h2>
    </div>

    <p class="text-sm text-gray-600 leading-relaxed text-center">
      3-year Bachelor’s degree in any discipline with at least 50% marks or equivalent CGPA
      from a recognized University or Institution as per the UGC Act, 1956, or possess an
      equivalent qualification recognized by the Ministry of Education, Government of India.
    </p>

  </div>
</section>

            <!-- SUCCESS STORIES (with modal video popup) -->
<section id="success-stories" class="py-6 md:py-5 bg-gray-50 scroll-mt-20 mb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 md:mb-8">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-[#573865] mb-3">Success Stories</h2>
<!--       <p class="text-muted-foreground">Hear from our alumni</p> -->
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6">
      <!-- Card 1 -->
      <div class="bg-white rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg transition-shadow group">
        <div
          class="relative aspect-video cursor-pointer overflow-hidden"
          data-modal-trigger
          data-title="Richa's Journey"
          data-video="https://www.youtube.com/embed/aHaP9kanqlw?autoplay=1"
          role="button"
          tabindex="0"
          aria-label="Play Richa's Journey video"
        >
          <img
            src="assets/testimonial-richa.webp" alt="Richa" loading="lazy" decoding="async" width="600" height="338" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
