<script>
document.addEventListener("DOMContentLoaded", () => {
  const marquee = document.querySelector("#career-scroll .career-marquee");
  const track   = document.querySelector("#career-scroll .career-track");
  if (!marquee || !track) return;

  let items = Array.from(track.querySelectorAll(".career-item"));

  // speed: pixels per second
  const SPEED = 60;
  let x = 0;
  let lastTs = null;

function visibleCount() {
  const w = window.innerWidth;
  if (w < 768) return 2;   // all mobiles = 2 cards
  return 5;                // desktop
}
  function applySizes() {
    items = Array.from(track.querySelectorAll(".career-item"));

    const vw = marquee.clientWidth;   // IMPORTANT: viewport width, not window
    const gap = window.innerWidth < 768 ? 12 : 16;

    const visible = visibleCount();
    const cardW = Math.floor((vw - gap * (visible - 1)) / visible);

    // Make the track behave like a row with spacing
    track.style.display = "flex";
    track.style.gap = gap + "px";
    track.style.willChange = "transform";

    // CRITICAL: set flex-basis (not just width), so cards don't stretch
    items.forEach((item) => {
      item.style.flex = `0 0 ${cardW}px`;
      item.style.width = `${cardW}px`;
    });

    // Reset position on resize so it doesn't get stuck mid-way
    x = 0;
    track.style.transform = `translate3d(${x}px,0,0)`;
  }

  // Infinite smooth scroll
  function tick(ts) {
    if (!lastTs) lastTs = ts;
    const dt = (ts - lastTs) / 1000;
    lastTs = ts;

    const half = track.scrollWidth / 2; // because you duplicated the set
    x -= SPEED * dt;

    // reset when the first set fully passed
    if (Math.abs(x) >= half) x = 0;

    track.style.transform = `translate3d(${x}px,0,0)`;
    requestAnimationFrame(tick);
  }

  applySizes();
  window.addEventListener("resize", () => {
    clearTimeout(window.__careerResizeT);
    window.__careerResizeT = setTimeout(applySizes, 120);
  });

  requestAnimationFrame(tick);
});
</script>
